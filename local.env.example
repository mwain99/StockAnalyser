 # =============================================================
# Stock Analyser - Environment Configuration
# =============================================================
# Copy this file to local.env and fill in your values:
#   cp local.env.example local.env
#
# local.env is in .gitignore and will never be committed.
# Never put real credentials in this example file.
# =============================================================

# --- Polygon / Massive API ---
API_KEY=your_polygon_api_key_here
API_BASE_URL=https://api.polygon.io

# --- Date Range ---
START_DATE=2025-01-01
END_DATE=2025-12-31

# --- Spark ---
SPARK_APP_NAME=StockAnalyser
SPARK_MASTER=local[*]

# --- Paths ---
OUTPUT_DIR=output
INPUT_FILE=data/stocks_list.csv

# --- Investment ---
TOTAL_INVESTMENT=1000000
INVESTMENT_PER_STOCK=10000

# --- API Rate Limiting ---
# Free tier (5 req/min)  → API_REQUEST_DELAY=12, API_MAX_WORKERS=1
# Starter  (100 req/min) → API_REQUEST_DELAY=0,  API_MAX_WORKERS=5
# Developer+ (unlimited) → API_REQUEST_DELAY=0,  API_MAX_WORKERS=20
API_REQUEST_DELAY=12
API_MAX_WORKERS=1

# --- API Reliability ---
API_REQUEST_TIMEOUT=30
API_MAX_RETRIES=3
API_RETRY_BACKOFF=1.5
